# Sunshine — copy to .env and fill. NEVER commit .env.
# --- model registry (backend-agnostic) ---
MAIN_MODEL=qwen3.5-4b
WORKER_MODEL=qwen3.5-0.8b
LLM_BACKEND=1cat-vllm          # swappable: 1cat-vllm | vllm | llamacpp | openai
# --- endpoints (filled by compose) ---
MAIN_URL=http://reason:8000/v1
WORKER_URL=http://fast:8000/v1
MEMORY_URL=http://memory:8000
VERIFY_URL=http://verify:8000
# --- secrets (examples — real values go in .env) ---
CF_TUNNEL_TOKEN=
SEARXNG_SECRET=
HF_TOKEN=
